@article{bpolandstudy,
  abstract = {The growth of the electric vehicles (EVs) use forces a need of verification their emissivity due to the electric power source. The thesis of non-emissivity EV is contested. Based on the average conditions of the Polish generation system and distribution network, real energy demand to charge EVs was calculated. Then the emissions were set and compared to the classic cars with internal combustion engine (ICE) according to Euro standards to check what real emissions are for EV and classic cars. For the averaged cases of the low voltage distribution system it turned out, that charging the electric vehicles from the mains results in higher exhaust gases production than the ICE cars. The energy losses are especially high for rural areas, where distances from the energy source to load are significant. This causes higher emissions than in cases of ICE. However the application of the renewable energy sources (RES) may be a best way to achieve zero-emissivity transportation, both in local scale (home RES supplying EV) and in whole system scale by lowering the average emissions substituting fossil fuels sources.},
  author = {Albrechtowicz, Paweł},
  address = {AMSTERDAM},
  copyright = {2023 The Author},
  issn = {2352-4847},
  journal = {Energy reports},
  keywords = {Electric vehicles ;  Energy consumption ;  Technology},
  language = {eng},
  pages = {3813-3821},
  publisher = {Elsevier Ltd},
  title = {Electric vehicle impact on the environment in terms of the electric energy source — Case study},
  volume = {9},
  year = {2023},
  note = {
    Albrechtowicz conducted a case study on the Green House Gas (GHG) emmissions
      of both Electric Vehicles (EV) and Internal Combustion Engine Vehicles
      (ICE). It focused on Poland in 2022 for its scope and limited the analysis
      to cars of that year. Poland's energy is 80% produced by coal. This study
      showed that at high usage of GHG emitting energy sources can make EVs
      less efficient than ICE vehicles. It also argues that EVs still have less
      measurable benifits like lower polution in cities since the emissions
      happen else where. It also advocates for the improvement of infrastructure
      and residential solar panels in order to make the transmissions more
      efficient.
  }
}

@BOOK{bstopsavingtheplanet,
  title     = "Stop saving the planet!",
  author    = "Price, Jenny",
  publisher = "WW Norton",
  month     =  apr,
  year      =  2021,
  address   = "New York, NY",
  language  = "en",
  note = {
    Jenny Price lays out critique of American Enviromentalism. This critique
      focuses on how standard enviromentalism occuring in the US tends to focus
      on separating humans from the enviroment, rather than acknowledging that
      the enviroment has an outsized impact on our lives and health. She
      designates these two approaches to enviromentalism as being "out there"
      and "in here" respectively. She critiques the phenomenon of "green virtue"
      where individuals are valorized for what is precived as enviromental
      action no matter the efficacy or amount of action taken. Additionally,
      she critiques how Capitalism is used as a solution to the crisis, arguing
      that the system of uncapped growth will not be able to handle getting us
      out of a problem of overusage. While not being about EVs directly, there
      is a lot to say about the regulation and tax credits of EVs being a
      consumerist approach to enviromental problems and the passing of
      responsibility from government and corporations to consumers. In
      addition, there is parallels to be drawn of the most financially weak
      communities being the least affected by the solution and most affected by
      the problem.
  }
}

@article{bghgforev,
  title = {Taking into account greenhouse gas emissions of electric vehicles for transportation de-carbonization},
  journal = {Energy Policy},
  volume = {155},
  pages = {112353},
  year = {2021},
  issn = {0301-4215},
  doi = {https://doi.org/10.1016/j.enpol.2021.112353},
  url = {https://www.sciencedirect.com/science/article/pii/S0301421521002238},
  author = {Yu Gan and Michael Wang and Zifeng Lu and Jarod Kelly},
  keywords = {Greenhouse gas, Vehicle fuel consumption/economy regulation, Well-to-wheels, Plug-in electric vehicles},
  abstract = {Plug-in electric vehicles pose great potentials to de-carbonize the transportation sector. To jump-start their market deployment, regulations in China, the U.S., and the European Union provide preferential treatments, including counting a single plug-in electric vehicle with multipliers (super-credits) in calculating sales-averaged emissions (regulation dilution effect) and considering zero emissions for the electric mileage by omitting electricity generation emissions (regulation leakage effect). This study quantifies greenhouse gas emission increases due to these two effects in the three markets. We show that plug-in electric vehicles sold in 2012–2025 in the three markets will result in greenhouse gas emission increases of more than 1 billion tonnes of CO2 equivalent through 2050 relative to the case without the two effects. The increase is 671, 280, and 143 million tonnes in China, the U.S., and the EU, respectively. The dilution effect causes an increase of 615 million tonnes, and the leakage effect 479 million tonnes. As the plug-in electric vehicle market grows, their super-credits should be gradually withdrawn, and well-to-wheels emissions need to be considered to achieve holistic greenhouse gas emission reductions. Future regulations should be carefully designed to incentivize new technologies while mitigating the risk of increasing emissions elsewhere so that the intent of environmental regulations is not compromised.},
  note = {
    The authors of this paper did an analysis on how the emission credits
      system used for EVs give preferential treatment to EVs that end up
      missing a significant amount of the emmissions produced by EVs over long
      enough time. As the future keeps approaching, more and more will be
      undercounted due to the "dilution effect" and the "leakage effect", or
      the effects of having super-credits and multipliers for EVs and not
      measuring the emissions from the source at the power plant. This is
      is useful for demonstrating that many of the policies that favor EVs are
      inaccurate and incorrectly favor EVs when they should not.
  }
}

@Article{bgermanimpact,
  author={Bekel, Kai
    and Pauliuk, Stefan},
  title={Prospective cost and environmental impact assessment of battery and fuel cell electric vehicles in Germany},
  journal={The International Journal of Life Cycle Assessment},
  year={2019},
  month={Dec},
  day={01},
  volume={24},
  number={12},
  pages={2220-2237},
  abstract={The goal of this study was to provide a holistic, reliable, and transparent comparison of battery electric vehicles (BEVs) and fuel cell electric vehicles (FCVs) regarding their environmental impacts (EI) and costs over their whole life cycle. The comprehensive knowledge about EI and costs forms the basis on which to decide which technology should be favored for the future of mobility.},
  issn={1614-7502},
  doi={10.1007/s11367-019-01640-8},
  url={https://doi.org/10.1007/s11367-019-01640-8},
  note={
    Bekel and Pauliuk preformed a life cycle assesment and comparison between
      Petrol, Battery Electric Vehicles, and Fuel Cell Vehicles. They compared
      the Global Warming Potential (GWP), Human Toxicity Potential (HTPnc),
      Surplus Ore Potential (SOP), and Particulat Mater Formation Potential
      (PMFP). While the EVs come out ahead of the ICE Vehicles in GWP by a
      significant marigin, they are behind in various degrees in the other
      compared parts of the study. This is a useful study to demonstrate how
      the ecological impact are not as simple as the impact on climate change.
      Many of the impacts that EVs are worse in impact worse off communities
      more than the wealthy communities that are able to afford new vehicles.
  }
}

@article{bpublictransitreduction,
  author = {Frank Gallivan and Jeff Ang-Olson and Cris B. Liban and Alvin Kusumoto},
  title ={Cost-Effective Approaches to Reduce Greenhouse Gas Emissions through Public Transportation in Los Angeles, California},
  journal = {Transportation Research Record},
  volume = {2217},
  number = {1},
  pages = {19-29},
  year = {2011},
  doi = {10.3141/2217-03},
  URL = { https://doi.org/10.3141/2217-03 },
  eprint = { https://doi.org/10.3141/2217-03 } ,
  abstract = { The Los Angeles County, California, Metropolitan Transportation Authority (Metro) commissioned a study of strategic options for the agency to reduce greenhouse gas (GHG) emissions. This study compared a comprehensive range of strategies on potential GHG reductions and cost-effectiveness, in dollars per ton of GHG emissions reduced. Sixteen strategies were analyzed in four categories: promotion of alternative travel modes, transit service, vehicle technology, and facility energy use. Strategies with the greatest potential for GHG emission reductions (regardless of cost) included transit-oriented development, vanpool subsidy, onboard railcar energy storage, and ridesharing and transit programs for employers. The first three would save or generate money for Metro. Ridesharing and transit programs have the potential for net revenue generation, but the results were uncertain. Four more strategies would reduce smaller amounts of emissions while also saving money for the agency: recycled water for bus washing, low-water sanitary fixtures, Red Line tunnel lighting retrofits, and facility lighting efficiency. Understanding opportunities for GHG reductions requires expertise in transit operations, vehicles, facilities, and planning. Cost-effectiveness and total reduction potential can be supporting criteria in making funding decisions. The largest GHG reduction opportunities for Metro are typically those that reduce vehicle miles traveled, whereas many of the most cost-effective strategies address GHG emissions from facility energy use. Cost-effectiveness of a strategy to Metro can depend greatly on receipt of external funding, including federal funds or utility rebates. In some cases, the range of cost-effectiveness for a strategy is so great that it is not useful to inform decision making without some further definition. },
  note = {
    The authors of this paper preformed an analysis to determine what the most
      effective ways of reducing carbon emissions through investment in public
      transit in Los Angeles. This analysis looked at cost over the long term
      and discovered a significant amount of places that could have lower costs
      or be at minimal costs. While this study is on the older side, it is a
      good demonstration of the fact that investments into public transit are
      very cost effective for the reduction of emissions.
  }
}

@article{bevequity,
  title = {Equity issues associated with U.S. plug-in electric vehicle income tax credits},
  journal = {Transportation Research Part D: Transport and Environment},
  volume = {102},
  pages = {103159},
  year = {2022},
  issn = {1361-9209},
  doi = {https://doi.org/10.1016/j.trd.2021.103159},
  url = {https://www.sciencedirect.com/science/article/pii/S1361920921004545},
  author = {Haobing Liu and Ziyi Dai and Michael O. Rodgers and Randall Guensler},
  keywords = {Plug-in electric vehicle (PEV), Income tax credit (ITC), Transportation equity, Motor vehicle energy use and emissions},
  abstract = {This research evaluated the accessibility of federal- and states-level Plug-in Electric Vehicles (PEVs) Income Tax Credits (ITC) policy in the United States, and identified potential barriers for households with diverse income levels, family types and number of children in participation. For example, a two-adults one-child family with an annual income of $82,600 (2019 U.S. national median income for three-people family) is eligible for only 70% of $7,500 federal ITC. Credits are even less available for families with lower income or more children. Based on a demographic case study in Georgia, 62.1% of Atlanta households are not eligible for full federal ITC. Further complicating any policy benefits assessments is that vehicles from lower-income households (less eligible for ITCs) produce higher emissions, which would yield criteria pollutant emission reduction benefits if replaced with PEVs. The study provided a reference for policy-makers to identify potential equity issues concealed in PEV tax credit programs.},
  note = {
    The authors of this study investigated the EV Tax Credit rules and
      eligibility in the US. The study deomonstrates how the tax credits
      almost exclusively benifit higher income individuals and households.
      There is a minimum amount of money that needs to be made in order to
      benifit from the credit which is around \$45k depending on the type of
      credit. As for state credits, only Montana has a credit that has a limit
      for the upper income where it can be applied and applies to those under
      that limit. This study is helpful for demonstrating how tax credits
      only advantage the wealthy and emphensises the inequity of ecological
      impacts in an avoidble and artifitial way.
  }
}

